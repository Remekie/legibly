PORT=3000
NODE_ENV=development

# Required: Claude API (Prompts This Page Should Be Winning)
ANTHROPIC_API_KEY=

# Required: Resend (email gate on full breakdown)
RESEND_API_KEY=

# GitHub OAuth — create at github.com/settings/developers → OAuth Apps
# Callback URL: https://legibly-production.up.railway.app/api/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SESSION_SECRET=change-me-in-production

# Stripe — get keys from dashboard.stripe.com
STRIPE_SECRET_KEY=
APP_URL=https://legibly-production.up.railway.app

# Week 3+: Firecrawl (llms.txt generation)
FIRECRAWL_API_KEY=
